{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SALN Form",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string" },
    "form_metadata": {
      "type": "object",
      "properties": {
        "form_type": { "type": "string" },
        "compliance_type": { "type": ["string", "null"] },
        "as_of_date": { "type": ["string", "null"], "format": "date" },
        "filing_type": { "type": ["string", "null"] }
      },
      "required": ["form_type", "compliance_type", "as_of_date", "filing_type"]
    },
    "declarant": {
      "type": "object",
      "properties": {
        "personal_information": {
          "type": "object",
          "properties": {
            "last_name": { "type": ["string", "null"] },
            "first_name": { "type": ["string", "null"] },
            "middle_initial": { "type": ["string", "null"] },
            "position": { "type": ["string", "null"] },
            "agency_office": { "type": ["string", "null"] },
            "office_address": { "type": ["string", "null"] },
            "government_id": {
              "type": "object",
              "properties": {
                "type": { "type": ["string", "null"] },
                "id_number": { "type": ["string", "null"] },
                "date_issued": { "type": ["string", "null"], "format": "date" }
              },
              "required": ["type", "id_number", "date_issued"]
            }
          },
          "required": ["last_name", "first_name", "middle_initial", "position", "agency_office", "office_address", "government_id"]
        }
      },
      "required": ["personal_information"]
    },
    "spouses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "is_public_official": { "type": "boolean" },
          "last_name": { "type": ["string", "null"] },
          "first_name": { "type": ["string", "null"] },
          "middle_initial": { "type": ["string", "null"] },
          "position": { "type": ["string", "null"] },
          "agency_office": { "type": ["string", "null"] },
          "office_address": { "type": ["string", "null"] }
        },
        "required": ["is_public_official", "last_name", "first_name", "middle_initial", "position", "agency_office", "office_address"]
      }
    },
    "children_below_18": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": ["string", "null"] },
          "age": { "type": ["string", "null", "number"] }
        }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "real_properties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": ["string", "null"] },
              "kind": { "type": ["string", "null"] },
              "exact_location": { "type": ["string", "null"] },
              "assessed_value": { "type": ["string", "null", "number"] },
              "fair_market_value": { "type": ["string", "null", "number"] },
              "acquisition": {
                "type": "object",
                "properties": {
                  "year": { "type": ["string", "null"] },
                  "mode": { "type": ["string", "null"] },
                  "cost": { "type": ["string", "null", "number"] }
                }
              }
            }
          }
        },
        "personal_properties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": ["string", "null"] },
              "acquisition_year": { "type": ["string", "null"] },
              "acquisition_cost": { "type": ["string", "null", "number"] }
            }
          }
        }
      },
      "required": ["real_properties", "personal_properties"]
    },
    "liabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nature": { "type": ["string", "null"] },
          "creditor_name": { "type": ["string", "null"] },
          "outstanding_balance": { "type": ["string", "null", "number"] }
        }
      }
    },
    "business_interests": {
      "type": "object",
      "properties": {
        "has_business_interest": { "type": "boolean" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity_name": { "type": ["string", "null"] },
              "business_address": { "type": ["string", "null"] },
              "nature_of_interest": { "type": ["string", "null"] },
              "date_acquired": { "type": ["string", "null"] }
            }
          }
        }
      },
      "required": ["has_business_interest", "entries"]
    },
    "relatives_in_government": {
      "type": "object",
      "properties": {
        "has_relatives": { "type": "boolean" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "relative_name": { "type": ["string", "null"] },
              "relationship": { "type": ["string", "null"] },
              "position": { "type": ["string", "null"] },
              "agency_office": { "type": ["string", "null"] }
            }
          }
        }
      },
      "required": ["has_relatives", "entries"]
    },
    "certification": {
      "type": "object",
      "properties": {
        "date_signed": { "type": ["string", "null"], "format": "date" },
        "authorization_to_verify": { "type": "boolean" }
      },
      "required": ["date_signed", "authorization_to_verify"]
    }
  },
  "required": [
    "schema_version",
    "form_metadata",
    "declarant",
    "spouses",
    "children_below_18",
    "assets",
    "liabilities",
    "business_interests",
    "relatives_in_government",
    "certification"
  ]
}
